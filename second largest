#include<stdio.h>

int main()
{
    int n;

    scanf("%d",&n);

    int a[n];

    for(int i=0;i<n;i++)
        scanf("%d",&a[i]);

    int max=a[0];
    int s=-99999;

    for(int i=1;i<n;i++)
    {
        if(a[i]>max)
        {
            s=max;
            max=a[i];
        }
        else if(a[i]>s && a[i]!=max)
            s=a[i];
    }

    printf("%d",s);

    return 0;
}
