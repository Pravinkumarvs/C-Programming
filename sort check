#include<stdio.h>

int main()
{
    int n,f=1;

    scanf("%d",&n);

    int a[n];

    for(int i=0;i<n;i++)
        scanf("%d",&a[i]);

    for(int i=0;i<n-1;i++)
    {
        if(a[i]>a[i+1])
        {
            f=0;
            break;
        }
    }

    if(f)
        printf("Sorted");
    else
        printf("Not Sorted");

    return 0;
}
